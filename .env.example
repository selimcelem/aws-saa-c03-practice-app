# AWS SAA-C03 Practice App — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ─── AWS Region ───────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1

# ─── Amazon Cognito ───────────────────────────────────────────────────────────
# Obtained from: terraform output after running terraform apply in /infra
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_DOMAIN=your-app-name.auth.eu-west-1.amazoncognito.com

# ─── Amazon S3 ────────────────────────────────────────────────────────────────
# Obtained from: terraform output after running terraform apply in /infra
S3_BUCKET_NAME=saa-c03-practice-XXXXXXXXXXXX

# ─── Google OAuth (for Cognito social identity provider) ──────────────────────
# Obtained from: Google Cloud Console → APIs & Services → Credentials
# DO NOT commit real values — these are secrets
GOOGLE_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── App OAuth Callback URLs ──────────────────────────────────────────────────
# Used in Cognito App Client settings and Google OAuth Authorized redirect URIs
OAUTH_CALLBACK_WINDOWS=http://localhost
OAUTH_CALLBACK_ANDROID=selimcelemsaaapp://callback
