<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AwsSaaC03Practice.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:AwsSaaC03Practice.ViewModels"
    xmlns:model="clr-namespace:AwsSaaC03Practice.Models">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,16">
            <VerticalStackLayout>
                <Label Text="{Binding UserName, StringFormat='Hey, {0}'}"
                       Style="{StaticResource HeadingStyle}" />
                <Label Text="{Binding UserEmail}" Style="{StaticResource SubheadingStyle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Reset Data" VerticalOptions="Center"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding ResetAllDataCommand}" FontSize="11"
                    Padding="10,8" />
            <Button Grid.Column="2" Text="Sign out" VerticalOptions="Center"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding SignOutCommand}" FontSize="12" />
        </Grid>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- Metric row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Style="{StaticResource MetricCardStyle}">
                        <VerticalStackLayout>
                            <Label Text="{Binding OverallScore, StringFormat='{0}%'}"
                                   FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                                   HorizontalOptions="Center" />
                            <Label Text="Overall Score" Style="{StaticResource SubheadingStyle}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <VerticalStackLayout>
                            <Label Text="{Binding StudyStreak, StringFormat='{0}🔥'}"
                                   FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Warning}"
                                   HorizontalOptions="Center" />
                            <Label Text="Day Streak" Style="{StaticResource SubheadingStyle}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <VerticalStackLayout>
                            <Label Text="{Binding TotalSessions}"
                                   FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Success}"
                                   HorizontalOptions="Center" />
                            <Label Text="Sessions" Style="{StaticResource SubheadingStyle}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Last session card -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Last Session" Style="{StaticResource SubheadingStyle}" />
                        <Label Text="{Binding LastSessionSummary}"
                               TextColor="{StaticResource TextPrimary}" FontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <!-- Domain scores -->
                <Border Style="{StaticResource CardStyle}"
                        IsVisible="{Binding DomainScores.Count, Converter={StaticResource CountToVisible}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Domain Performance" Style="{StaticResource SubheadingStyle}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding DomainScores}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:DomainScore">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,8">
                                        <Label Text="{Binding Domain}" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Percent, StringFormat='{0}%'}"
                                               FontSize="12" TextColor="{Binding Colour}" />
                                        <AbsoluteLayout Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="8">
                                            <BoxView AbsoluteLayout.LayoutBounds="0,0,1,1"
                                                     AbsoluteLayout.LayoutFlags="All"
                                                     BackgroundColor="{StaticResource BgCardAlt}"
                                                     CornerRadius="4" />
                                            <BoxView AbsoluteLayout.LayoutBounds="{Binding Fraction, Converter={StaticResource FractionToRect}}"
                                                     AbsoluteLayout.LayoutFlags="All"
                                                     BackgroundColor="{Binding Colour}"
                                                     CornerRadius="4" />
                                        </AbsoluteLayout>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Sync status -->
                <Label Text="{Binding SyncStatus}"
                       Style="{StaticResource SubheadingStyle}"
                       HorizontalOptions="End" FontSize="11"
                       IsVisible="{Binding SyncStatus, Converter={StaticResource IsNotEmpty}}" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Start studying button -->
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Button Text="Start Studying  →"
                    Command="{Binding GoToModePickerCommand}"
                    Margin="0,12,0,0" FontSize="17" />
            <Label Text="Support this project ☕" FontSize="12"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSupportTapped" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
