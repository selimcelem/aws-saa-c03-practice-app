<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AwsSaaC03Practice.Views.QuizPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,16">

        <!-- Header: progress + timer + stop -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
            <VerticalStackLayout>
                <Label Text="{Binding ProgressText}" Style="{StaticResource SubheadingStyle}" />
                <Label Text="{Binding CurrentQuestion.Domain}" FontSize="11"
                       TextColor="{StaticResource AccentSubtle}" />
            </VerticalStackLayout>
            <Label Grid.Column="1" Text="{Binding TimerText}"
                   IsVisible="{Binding TimerVisible}"
                   TextColor="{StaticResource Warning}" FontAttributes="Bold"
                   FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
            <Button Grid.Column="2" Text="Stop"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding StopCommand}"
                    FontSize="13" Padding="12,8" />
        </Grid>

        <!-- Question + answers scroll -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- Question text -->
                <Border Style="{StaticResource CardStyle}">
                    <Label Text="{Binding CurrentQuestion.Text}"
                           FontSize="16" LineHeight="1.5"
                           TextColor="{StaticResource TextPrimary}" />
                </Border>

                <!-- Option buttons — BackgroundColor driven by ViewModel Color properties -->
                <!-- Answer options — using Border+Label for reliable text wrapping -->
                <VerticalStackLayout Spacing="10">
                    <Border Style="{StaticResource AnswerOptionStyle}"
                            BackgroundColor="{Binding Opt0Colour}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAnswerCommand}" CommandParameter="0" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Option0Text}" Style="{StaticResource AnswerLabelStyle}" />
                    </Border>
                    <Border Style="{StaticResource AnswerOptionStyle}"
                            BackgroundColor="{Binding Opt1Colour}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAnswerCommand}" CommandParameter="1" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Option1Text}" Style="{StaticResource AnswerLabelStyle}" />
                    </Border>
                    <Border Style="{StaticResource AnswerOptionStyle}"
                            BackgroundColor="{Binding Opt2Colour}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAnswerCommand}" CommandParameter="2" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Option2Text}" Style="{StaticResource AnswerLabelStyle}" />
                    </Border>
                    <Border Style="{StaticResource AnswerOptionStyle}"
                            BackgroundColor="{Binding Opt3Colour}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAnswerCommand}" CommandParameter="3" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Option3Text}" Style="{StaticResource AnswerLabelStyle}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Answer reveal panel -->
                <Border Style="{StaticResource CardStyle}"
                        IsVisible="{Binding AnswerRevealed}"
                        BackgroundColor="#1a2744">
                    <VerticalStackLayout Spacing="10">
                        <Border Style="{StaticResource PillStyle}"
                                BackgroundColor="{StaticResource AccentSubtle}"
                                HorizontalOptions="Start">
                            <Label Text="{Binding CurrentQuestion.Category}"
                                   TextColor="{StaticResource Accent}" FontSize="12" />
                        </Border>
                        <Label Text="{Binding ExplanationText}"
                               FontSize="14" LineHeight="1.5"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Next button -->
        <Button Grid.Row="2" Text="Next  →"
                Command="{Binding NextCommand}"
                IsVisible="{Binding AnswerRevealed}"
                Margin="0,12,0,0" FontSize="16" />

    </Grid>
</ContentPage>
