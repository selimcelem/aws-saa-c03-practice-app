<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for certificate pinning.
  Pins AWS service endpoints to Amazon Root CAs to prevent MITM attacks.
  Android enforces this at the OS level for all HTTP(S) calls.

  Pin set includes Amazon Root CA 1-4 and Starfield Services Root CA G2.
  expiration: set to 2027-01-01 — review and rotate before this date.
-->
<network-security-config>
  <!-- Default: block cleartext (HTTP); only allow HTTPS -->
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>

  <!-- Pin Amazon/AWS endpoints to Amazon Root CAs -->
  <domain-config>
    <domain includeSubdomains="true">amazonaws.com</domain>
    <domain includeSubdomains="true">amazoncognito.com</domain>
    <pin-set expiration="2027-01-01">
      <!-- Amazon Root CA 1 (RSA 2048) -->
      <pin digest="SHA-256">++MBgDH5WGvL9Bcn5Be30cRcL0f5O+NyoXuWtQdX1aI=</pin>
      <!-- Amazon Root CA 2 (RSA 4096) -->
      <pin digest="SHA-256">f0KW/FtqTjs108NpYj42SrGvOB2PpxIVM8nWxjPqJGE=</pin>
      <!-- Amazon Root CA 3 (EC P256) -->
      <pin digest="SHA-256">NqvDJlas/GRcYbcWE8S/IceM39HUUhT5vQ+jF8LhAUI=</pin>
      <!-- Amazon Root CA 4 (EC P384) -->
      <pin digest="SHA-256">9+ze1cZgR9KO1kZrVDxA4HQ6voHRCSVNz4RdTCx4U8U=</pin>
      <!-- Starfield Services Root Certificate Authority - G2 (Amazon legacy) -->
      <pin digest="SHA-256">KwccWaCgrnaw6tsrrSO61FgLacNgG2MMLq8GE6+oP5I=</pin>
    </pin-set>
  </domain-config>

  <!-- Allow localhost for Windows OAuth callback (debug only) -->
  <domain-config cleartextTrafficPermitted="true">
    <domain>localhost</domain>
  </domain-config>
</network-security-config>
