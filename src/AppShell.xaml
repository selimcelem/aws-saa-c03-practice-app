<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AwsSaaC03Practice.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:AwsSaaC03Practice.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0d1117">

    <!-- Tab-less shell — navigation driven programmatically -->
    <ShellContent Route="login"      ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="dashboard"  ContentTemplate="{DataTemplate views:DashboardPage}" />
    <ShellContent Route="modepicker" ContentTemplate="{DataTemplate views:ModePickerPage}" />

</Shell>
