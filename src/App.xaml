<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="AwsSaaC03Practice.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AwsSaaC03Practice">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Converters (referenced as StaticResource in all views) ── -->
            <local:StringHelper x:Key="IsNotEmpty" />
            <local:CountToVisibility x:Key="CountToVisible" />
            <local:InvertBool x:Key="InvertBool" />
            <local:PercentToWidth x:Key="PercentToWidth" />

            <!-- ── Colour palette ── -->
            <Color x:Key="BgPage">#0d1117</Color>
            <Color x:Key="BgCard">#161b22</Color>
            <Color x:Key="BgCardAlt">#1c2128</Color>
            <Color x:Key="Border">#30363d</Color>
            <Color x:Key="TextPrimary">#c9d1d9</Color>
            <Color x:Key="TextSecondary">#8b949e</Color>
            <Color x:Key="Accent">#58a6ff</Color>
            <Color x:Key="AccentSubtle">#1f4173</Color>
            <Color x:Key="Success">#3fb950</Color>
            <Color x:Key="Warning">#d29922</Color>
            <Color x:Key="Danger">#f85149</Color>

            <!-- ── Global styles ── -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource BgPage}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontSize" Value="15" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
                <Setter Property="Stroke" Value="{StaticResource Border}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
                <Setter Property="Stroke" Value="{StaticResource Border}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="HorizontalOptions" Value="Fill" />
            </Style>

            <Style x:Key="HeadingStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="SubheadingStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="PillStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeThickness" Value="0" />
            </Style>

            <Style x:Key="AnswerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource BgCardAlt}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BorderColor" Value="{StaticResource Border}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Tappable answer option — Border+Label for reliable text wrapping -->
            <Style x:Key="AnswerOptionStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BgCardAlt}" />
                <Setter Property="Stroke" Value="{StaticResource Border}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="HorizontalOptions" Value="Fill" />
            </Style>

            <Style x:Key="AnswerLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
                <Setter Property="LineHeight" Value="1.3" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource Danger}" />
                <Setter Property="BorderColor" Value="{StaticResource Danger}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,10" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                <Setter Property="BorderColor" Value="{StaticResource Accent}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,10" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
